#!/bin/sh
# commit-msg hook — conventional commits validator for the kanban-tasks repo
#
# Install with:
#   cp cicd/commit-msg .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg
# Or use the convenience installer:
#   cicd/install-hooks.sh
#
# NOTE: This hook enforces conventional commits in the kanban-tasks dev repo.
# It is separate from the commit-msg hook that kanban installs in user repos
# (installed by: kanban install-hook), which handles task state transitions
# and always exits 0.
#
# Valid format: <type>[optional scope][optional !]: <description>
#
# Types: feat, fix, chore, docs, test, refactor, ci, style, perf
# Examples:
#   feat(board): add WIP column limit
#   fix: prevent duplicate task IDs on concurrent writes
#   chore!: drop support for Go 1.21 (breaking change)
#   ci(release): pin goreleaser to v2.3.2

COMMIT_MSG_FILE="$1"
COMMIT_MSG="$(cat "$COMMIT_MSG_FILE")"

# Skip merge commits (generated by git, not written by developer)
case "$COMMIT_MSG" in
    Merge\ *) exit 0 ;;
esac

# Skip fixup and squash commits (generated by git rebase --autosquash)
case "$COMMIT_MSG" in
    fixup!\ *|squash!\ *) exit 0 ;;
esac

# Validate against conventional commits pattern
PATTERN="^(feat|fix|chore|docs|test|refactor|ci|style|perf)(\([a-z0-9/_-]+\))?!?: .+"

FIRST_LINE="$(echo "$COMMIT_MSG" | head -n1)"

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
    echo ""
    echo "  ✗ commit-msg: message does not follow conventional commits format"
    echo ""
    echo "  Got: $FIRST_LINE"
    echo ""
    echo "  Expected: <type>[optional scope][optional !]: <description>"
    echo ""
    echo "  Valid types: feat, fix, chore, docs, test, refactor, ci, style, perf"
    echo ""
    echo "  Examples:"
    echo "    feat(board): add WIP column limit"
    echo "    fix: prevent duplicate task IDs on concurrent writes"
    echo "    chore!: drop support for Go 1.21"
    echo "    ci(release): pin goreleaser to v2.3.2"
    echo ""
    exit 1
fi

exit 0
